{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "lodestone",
  "version": "0.3.0",
  "identifier": "com.lodestone.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "lodestone",
        "width": 560,
        "height": 760,
        "minWidth": 440,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUyQkRGNTRERThGNDcxRkUKUldUK2NmVG9UZlc5VXU4VXRkYzZwZ2UraUxsRUJWVnQ1NWgwR2lXRE1zSlAxaXNGR2dMM3JBelAK",
      "endpoints": [
        "https://github.com/lulkebit/lodestone/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": {
      "../sidecar": "sidecar"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
